---
import BrandLayout from '../../layouts/BrandLayout.astro';
import { getBannerById, bannerEntryUrl, bannerFallbackUrl } from '../../lib/banners';

const { id } = Astro.params;
const b = id ? getBannerById(id) : undefined;

if (!b) {
	Astro.response.status = 404;
}

const previewDescription = b
	? [b.name, `${b.width}×${b.height}`, b.notes].filter(Boolean).join(' · ') +
			' — BannerWave work preview.'
	: undefined;
const ogImage = b && b.hasFallback ? bannerFallbackUrl(b.id) : undefined;
---

<BrandLayout
	title={b ? `${b.name} — Preview` : 'Not found'}
	description={previewDescription ?? 'This preview is not in the archive.'}
	ogTitle={b ? `${b.name} — Preview` : 'Preview not found — BannerWave'}
	ogDescription={previewDescription}
	ogImage={ogImage}
>
	{
		b ? (
			<div
				style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1rem; background: radial-gradient(ellipse at center, #1a2a36 0%, #0a0f14 70%);"
			>
				<iframe
					src={bannerEntryUrl(b.id)}
					title={b.name}
					width={b.width}
					height={b.height}
					style="border: 0; box-shadow: 0 12px 48px rgba(0,0,0,0.45); max-width: 100%; background: #000;"
				/>
				<p style="margin-top: 1rem; font-size: 0.75rem; color: var(--bw-muted);">
					{b.name} · {b.width}×{b.height}
				</p>
			</div>
		) : (
			<main style="padding: 3rem 1.5rem; text-align: center;">
				<h1 style="font-size: 1.25rem;">Preview not found</h1>
				<p style="color: var(--bw-muted);">
					<a href="https://bannerwave.com/">BannerWave</a>
				</p>
			</main>
		)
	}
</BrandLayout>
