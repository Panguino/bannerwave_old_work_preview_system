---
import BrandLayout from '../../layouts/BrandLayout.astro';
import { banners, bannerFallbackUrl } from '../../lib/banners';
---

<BrandLayout title="Banners — Admin">
	<div style="max-width: 1200px; margin: 0 auto; padding: 1.5rem 1rem 3rem;">
		<header
			style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem;"
		>
			<div>
				<h1 style="font-size: 1.5rem; margin: 0;">Banners</h1>
				<p style="margin: 0.25rem 0 0; color: var(--bw-muted); font-size: 0.9rem;">
					{banners.length} in library
				</p>
			</div>
			<div style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
				<label style="font-size: 0.875rem; color: var(--bw-muted); display: flex; align-items: center; gap: 0.5rem;">
					Filter
					<input
						id="bw-filter"
						type="search"
						placeholder="Name or keyword…"
						autocomplete="off"
						style="padding: 0.45rem 0.65rem; border-radius: 8px; border: 1px solid var(--bw-border); background: #0f172a; color: var(--bw-text); min-width: 12rem;"
					/>
				</label>
				<form method="post" action="/api/auth/logout">
					<button type="submit" class="bw-btn bw-btn-ghost" style="font-size: 0.875rem;"> Sign out </button>
				</form>
			</div>
		</header>

		<div
			id="bw-grid"
			style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem;"
		>
			{
				banners.map((b) => {
					const kw = [...b.keywords, ...(b.suggestedKeywords ?? [])].join(' ').toLowerCase();
					const hay = `${b.name} ${b.id} ${kw}`.toLowerCase();
					return (
						<a
							class="bw-card"
							href={`/admin/${b.id}`}
							data-filter={hay}
							style="text-decoration: none; color: inherit; overflow: hidden; display: flex; flex-direction: column;"
						>
							<div
								style={`aspect-ratio: ${b.width} / ${b.height}; background: #0f172a; position: relative; border-bottom: 1px solid var(--bw-border);`}
							>
								{b.hasFallback ? (
									<img
										src={bannerFallbackUrl(b.id)}
										alt=""
										loading="lazy"
										style="width: 100%; height: 100%; object-fit: cover; display: block;"
									/>
								) : (
									<div
										style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: var(--bw-teal); font-weight: 600; font-size: 0.9rem;"
									>
										{b.width} × {b.height}
									</div>
								)}
							</div>
							<div style="padding: 0.85rem 1rem 1rem; flex: 1;">
								<div style="display: flex; justify-content: space-between; gap: 0.5rem; align-items: flex-start;">
									<strong style="font-size: 0.95rem;">{b.name}</strong>
									<span
										style="font-size: 0.7rem; padding: 0.15rem 0.4rem; border-radius: 4px; background: #1e3a5f; color: #93c5fd;"
									>
										{b.status}
									</span>
								</div>
								<p style="margin: 0.35rem 0 0; font-size: 0.8rem; color: var(--bw-muted);">
									{b.width}×{b.height} · HTML5
								</p>
								{b.keywords.length > 0 && (
									<p style="margin: 0.5rem 0 0; font-size: 0.75rem; color: var(--bw-muted); line-height: 1.4;">
										{b.keywords.join(' · ')}
									</p>
								)}
							</div>
						</a>
					);
				})
			}
		</div>
	</div>

	<script>
		const input = document.getElementById('bw-filter');
		const cards = document.querySelectorAll('[data-filter]');
		input?.addEventListener('input', () => {
			const q = (input.value || '').trim().toLowerCase();
			cards.forEach((el) => {
				const hay = el.getAttribute('data-filter') || '';
				const show = !q || hay.includes(q);
				el.style.display = show ? '' : 'none';
			});
		});
	</script>
</BrandLayout>
