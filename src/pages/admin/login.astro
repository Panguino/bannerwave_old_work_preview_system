---
import BrandLayout from '../../layouts/BrandLayout.astro';

const redirect = Astro.url.searchParams.get('redirect') || '/admin';
const err = Astro.url.searchParams.get('error');
---

<BrandLayout title="Admin sign in — BannerWave preview">
	<main style="max-width: 22rem; margin: 0 auto; padding: 3rem 1.25rem;">
		<h1 style="font-size: 1.35rem; margin: 0 0 0.5rem;">Preview library</h1>
		<p style="color: var(--bw-muted); font-size: 0.9rem; margin: 0 0 1.5rem;">
			Sign in to browse archived banners.
		</p>
		{
			err && (
				<p style="color: #f87171; font-size: 0.875rem; margin: 0 0 1rem;">
					Invalid username or password.
				</p>
			)
		}
		<form
			class="bw-card"
			method="post"
			action={`/api/auth/login?redirect=${encodeURIComponent(redirect)}`}
			style="padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem;"
		>
			<label style="display: flex; flex-direction: column; gap: 0.35rem; text-align: left; font-size: 0.875rem;">
				Username
				<input
					name="username"
					autocomplete="username"
					required
					style="padding: 0.5rem 0.65rem; border-radius: 8px; border: 1px solid var(--bw-border); background: #0f172a; color: var(--bw-text);"
				/>
			</label>
			<label style="display: flex; flex-direction: column; gap: 0.35rem; text-align: left; font-size: 0.875rem;">
				Password
				<input
					type="password"
					name="password"
					autocomplete="current-password"
					required
					style="padding: 0.5rem 0.65rem; border-radius: 8px; border: 1px solid var(--bw-border); background: #0f172a; color: var(--bw-text);"
				/>
			</label>
			<button type="submit" class="bw-btn bw-btn-orange" style="width: 100%; margin-top: 0.25rem;">
				Sign in
			</button>
		</form>
		<p style="margin-top: 1.5rem; text-align: center;">
			<a href="/" style="color: var(--bw-muted); font-size: 0.875rem;">← Back to home</a>
		</p>
	</main>
</BrandLayout>
