---
interface Props {
	title: string;
	description?: string;
	/** Path (e.g. `/og-default.webp`) or full https URL. Defaults to BannerWave social art. */
	ogImage?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogType?: string;
	twitterCard?: 'summary' | 'summary_large_image';
	/**
	 * iOS touch/scroll: banner embeds in iframes fight page rubber-banding and scrolling.
	 * - `full` — public `/p/:id/`: lock host page + inject styles into the banner document.
	 * - `iframe` — admin (and similar): only inject + light wrapper; host page can still scroll.
	 */
	iosBannerLock?: 'full' | 'iframe';
}

const {
	title,
	description = 'BannerWave archived work preview.',
	ogImage,
	ogTitle,
	ogDescription,
	ogType = 'website',
	twitterCard = 'summary_large_image',
	iosBannerLock = undefined,
} = Astro.props;

const siteOrigin = Astro.url.origin;
const canonical = new URL(Astro.url.pathname, siteOrigin).href;

function toAbsolute(urlOrPath: string): string {
	if (urlOrPath.startsWith('http://') || urlOrPath.startsWith('https://')) {
		return urlOrPath;
	}
	return new URL(urlOrPath, siteOrigin).href;
}

const defaultOgImage = '/og-default.webp';
const ogImageAbs = toAbsolute(ogImage ?? defaultOgImage);
const metaTitle = ogTitle ?? title;
const metaDescription = ogDescription ?? description;
const viewportContent =
	iosBannerLock === 'full'
		? 'width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no'
		: 'width=device-width, initial-scale=1';
---

<!doctype html>
<html
	lang="en"
	class={iosBannerLock === 'full' ? 'bw-ios-banner-lock-full' : undefined}
>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content={viewportContent} />
		<meta name="description" content={metaDescription} />
		<link rel="canonical" href={canonical} />
		<meta property="og:site_name" content="BannerWave" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={metaTitle} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageAbs} />
		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={metaTitle} />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content={ogImageAbs} />
		<link rel="icon" href="/favicon-bw.ico" sizes="any" />
		<link rel="shortcut icon" href="/favicon-bw.ico" type="image/x-icon" />
		<title>{title}</title>
		<style is:global>
			:root {
				--bw-bg: #121e26;
				--bw-bg-elevated: #1a2a36;
				--bw-text: #f1f5f9;
				--bw-muted: #94a3b8;
				--bw-orange: #f97316;
				--bw-teal: #2dd4bf;
				--bw-border: #334155;
				--bw-font: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
			}
			*,
			*::before,
			*::after {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				min-height: 100vh;
				font-family: var(--bw-font);
				background: var(--bw-bg);
				color: var(--bw-text);
				line-height: 1.5;
			}
			a {
				color: var(--bw-teal);
			}
			a:hover {
				text-decoration: underline;
			}
			.bw-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.65rem 1.35rem;
				border-radius: 9999px;
				font-weight: 600;
				font-size: 0.95rem;
				text-decoration: none;
				border: none;
				cursor: pointer;
				transition: opacity 0.15s;
			}
			.bw-btn:hover {
				opacity: 0.92;
				text-decoration: none;
			}
			.bw-btn-orange {
				background: var(--bw-orange);
				color: #fff;
			}
			.bw-btn-teal {
				background: var(--bw-teal);
				color: #0f172a;
			}
			.bw-btn-ghost {
				background: transparent;
				color: var(--bw-muted);
				border: 1px solid var(--bw-border);
			}
			.bw-card {
				background: var(--bw-bg-elevated);
				border: 1px solid var(--bw-border);
				border-radius: 12px;
			}
			/* Public banner preview: stop iOS page rubber-banding / scroll stealing from the iframe area */
			html.bw-ios-banner-lock-full,
			html.bw-ios-banner-lock-full body {
				height: 100%;
				max-height: 100%;
			}
			html.bw-ios-banner-lock-full {
				overflow: hidden;
				overscroll-behavior: none;
			}
			html.bw-ios-banner-lock-full body {
				margin: 0;
				width: 100%;
				position: fixed;
				inset: 0;
				overflow: hidden;
				overscroll-behavior: none;
				-webkit-overflow-scrolling: auto;
			}
			.bw-banner-preview-stage {
				box-sizing: border-box;
				width: 100%;
				height: 100%;
				min-height: 100dvh;
				padding: 1rem;
				overflow: hidden;
				overscroll-behavior: none;
				touch-action: manipulation;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				background: radial-gradient(ellipse at center, #1a2a36 0%, #0a0f14 70%);
			}
			/* Admin (etc.): clip overscroll on the host around the ad only */
			.bw-banner-embed-shim {
				display: flex;
				justify-content: center;
				align-items: center;
				overflow: hidden;
				overscroll-behavior: none;
				touch-action: manipulation;
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
